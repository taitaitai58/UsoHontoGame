# Local environment overrides for Next.js
# Copy this file to .env.local and update the path to your project directory
# This file is loaded by Next.js and takes precedence over .env

# Use absolute path for DATABASE_URL in Next.js
# Replace /path/to/project with your actual project path
DATABASE_URL="file:/path/to/project/prisma/dev.db"

# Or use this command to generate it automatically:
# echo "DATABASE_URL=\"file:$(pwd)/prisma/dev.db\"" > .env.local
