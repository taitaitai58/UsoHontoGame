{
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["--yes", "@upstash/context7-mcp"],
      "env": {}
    },
    "mfui-developer-mcp": {
      "command": "node",
      "args": ["${MFUI_MCP_PATH}/apps/mcp-server/build/index.js"]
    }
  }
}
