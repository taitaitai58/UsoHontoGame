{
  "name": "uso_honto_game",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint:biome": "biome lint .",
    "check": "biome check --write .",
    "test": "vitest run",
    "test:unit": "vitest run --exclude='**/tests/integration/**'",
    "test:integration": "vitest run tests/integration --reporter=verbose",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:integration:api": "start-server-and-test 'next dev' http://localhost:3000 'vitest run tests/integration/api'",
    "test:integration:watch": "start-server-and-test 'next dev' http://localhost:3000 'vitest tests/integration/api'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@tanstack/react-query": "^5.90.10",
    "dotenv": "^17.2.3",
    "nanoid": "^5.1.6",
    "next": "16.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-window": "^1.8.11",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.4",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^4.0.7",
    "eslint": "^9",
    "eslint-config-next": "16.0.1",
    "jsdom": "^27.1.0",
    "prisma": "^6.19.0",
    "start-server-and-test": "^2.1.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.7"
  }
}
